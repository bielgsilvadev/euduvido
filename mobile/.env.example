# Copie para .env e preencha (Expo carrega EXPO_PUBLIC_* automaticamente com expo-env)
# Deploy na Vercel: as mesmas chaves têm de existir em Project → Settings → Environment Variables (Production), senão o build web fica sem Supabase.
EXPO_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Opcional: URLs dos legais. Se vazio, na web usam-se /terms e /privacy do mesmo deploy (Expo na Vercel).
# EXPO_PUBLIC_LEGAL_TERMS_URL=https://euduvido.vercel.app/terms
# EXPO_PUBLIC_LEGAL_PRIVACY_URL=https://euduvido.vercel.app/privacy

# Stripe no fluxo de desafios (opcional).
# EXPO_PUBLIC_STRIPE_ENABLED=true
# Nome da Edge Function usada para criar sessão de checkout.
# EXPO_PUBLIC_STRIPE_CHALLENGE_FN=create_challenge_checkout
# URL base pública para retorno do checkout (web/deeplink HTTP).
# EXPO_PUBLIC_APP_URL=https://euduvido.vercel.app

# NÃO uses este ficheiro para VERCEL_TOKEN / ORG_ID / PROJECT_ID.
# Esses valores vão só em GitHub → Settings → Secrets → Actions (workflow de deploy).
