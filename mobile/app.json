{
  "expo": {
    "name": "Eu Duvido!",
    "slug": "eu-duvido",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "euduvido",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0B"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.euduvido.app",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "O Eu Duvido! usa fotos para provas dos seus desafios.",
        "NSCameraUsageDescription": "O Eu Duvido! usa a câmera para registrar provas dos desafios."
      }
    },
    "android": {
      "package": "com.euduvido.app",
      "adaptiveIcon": {
        "backgroundColor": "#0A0A0B",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image",
      [
        "expo-image-picker",
        {
          "photosPermission": "O Eu Duvido! precisa de acesso às fotos para enviar provas.",
          "cameraPermission": "O Eu Duvido! usa a câmera para provas dos desafios."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "SUBSTITUA_PELO_PROJECT_ID_DO_EAS"
      },
      "supabaseUrl": "",
      "supabaseAnonKey": ""
    }
  }
}
